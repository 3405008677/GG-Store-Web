# 浏览器访问 Nuxt 的同源 API 前缀；不要改成后端的绝对跨域地址。
NUXT_PUBLIC_API_BASE=/

# 仅供本地开发的后端服务 Origin，不包含 /api；修改后需重启 Nuxt。
NUXT_ORDER_API_PROXY_TARGET=http://127.0.0.1:5080
NUXT_CATALOG_API_PROXY_TARGET=http://127.0.0.1:5081
NUXT_CART_API_PROXY_TARGET=http://127.0.0.1:5082
NUXT_MERCHANT_API_PROXY_TARGET=http://127.0.0.1:5083
NUXT_ADMIN_API_PROXY_TARGET=http://127.0.0.1:5084
NUXT_USER_MANAGE_API_PROXY_TARGET=http://127.0.0.1:5085
